# Porta deste servidor gerenciador
# As instancias criadas recebem um PORT proprio automaticamente no .env delas
PORT=3100

# Diretorio das instancias alpha existentes
APPS_DIR=./servicos_ias/

# Diretorio separado apenas para instancias trier
APPS_DIR_TRIER=./servicos_ias/trier

# Repositorio do alpha
REPO_URL=https://github.com/UnicoContato/alpha7_IA_view.git
REPO_BRANCH=main

# Repositorio da trier
TRIER_REPO_URL=
TRIER_REPO_BRANCH=main

# Faixa de portas reservada para as instancias de IA
# Cada nova instancia recebe automaticamente a proxima porta livre nessa faixa
PORTA_INICIO=5300
PORTA_FIM=5399

# CORS: use * to allow any origin or a comma-separated list
CORS_ORIGIN=*
